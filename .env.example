# Anthropic API (Primary LLM Provider)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI API (Fallback Provider)
OPENAI_API_KEY=sk-...

# Google APIs (YouTube Data API v3 + Gmail)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...

# Notion API
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...

# Gmail Delivery
GMAIL_SEND_ADDRESS=your-email@gmail.com

# Twitter/X (Optional - unofficial scraper)
TWITTER_USERNAME=your_username
TWITTER_PASSWORD=your_password

# Optional: Force delivery even in test mode
FORCE_DELIVERY=false
